# ROS 2 build artifacts (regenerated by colcon)
ros2_ws/build/
ros2_ws/install/
ros2_ws/log/

# Python bytecode & caches
__pycache__/
*.py[cod]
*$py.class
.pytest_cache/
.mypy_cache/
.ruff_cache/
*.egg-info/
.eggs/
venv/
.venv/

# Recorded bags / runtime logs (can be very large)
urc_logs/**/*.bag
urc_logs/**/*.mcap
*.bag
*.mcap

# macOS / editors
.DS_Store
.idea/
.vscode/
*.swp

# Secrets — never commit
.env
.env.*
